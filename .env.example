# Base URL menuju root REST API CodeIgniter kamu.
# Contoh: http://localhost/app-kas-api/public/api
VITE_API_BASE_URL="http://localhost/app-kas-api/public/api"

# Opsional: path endpoint sinkronisasi transaksi jika backend ingin dipisah.
# Default frontend akan memakai /transactions, /transactions/:id, dan /transactions/:id/cancel.
VITE_API_SYNC_PREFIX="/transactions"
